{
  "permissions": {
    "allow": [
      "Read(**)",
      "Grep",
      "Glob"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-prod-writes.sh"
          }
        ]
      }
    ]
  }
}
