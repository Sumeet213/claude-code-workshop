# Local artifacts and noise — don't commit these.

# Python venv (per-machine; recreated by scripts/setup.sh)
**/.venv/
**/__pycache__/
*.pyc

# Node
node_modules/

# Hook + MCP runtime artifacts
**/hook-debug.log
**/pages.log
**/audit.log
*.log

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp

# Local overrides
.claude/settings.local.json
.env
.env.local

# Testing scratch
/tmp/

# Sandbox repo's own git history is seeded by scripts/setup.sh on each
# participant's machine — we don't track it in the outer repo.
sandbox_repo/.git/
